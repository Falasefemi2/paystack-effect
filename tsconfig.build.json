{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "bundler"
  },
  "include": ["index.ts", "runtime.ts", "apis/**/*", "models/**/*"],
  "exclude": ["server.ts", "node_modules", "dist"]
}
